# Server
PORT=3000

# Auth (required for /auth/register and /auth/login)
JWT_SECRET=your-secret-key-min-32-chars-for-production

# Supabase (required for order storage and retrieval: POST /orders, GET /orders, etc.)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# DevEx Category 2 Despatch API (optional — POST/GET /orders/:id/despatch, GET /orders/despatch/list)
# Request a key: POST https://devex.cloud.tcore.network/api/v1/api-key/create
# Docs: https://devex.cloud.tcore.network/api-docs/
DEVEX_API_KEY=e20bf9de6767658dd5b1ab3a468f85a8655bb7dba00a559a16e876522bdadd89
# DEVEX_API_BASE_URL=https://devex.cloud.tcore.network

# Optional: set to "test" when running Jest (some tests expect this)
# NODE_ENV=test

# Email (required for POST /auth/forgot-password)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@example.com
