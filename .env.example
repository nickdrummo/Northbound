# Server
PORT=3000

# Auth (required for /auth/register and /auth/login)
JWT_SECRET=your-secret-key-min-32-chars-for-production

# Supabase (required for order storage and retrieval: POST /orders, GET /orders, etc.)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Optional: set to "test" when running Jest (some tests expect this)
# NODE_ENV=test
